{
  "name": "6il",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "description": "Snowfield colony survival + auto-battler. Fantasy medieval VS-like.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.6il.game",
    "productName": "6IL",
    "copyright": "Copyright 2026",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "6IL_v0.2.0_portable.exe"
    },
    "files": [
      "main.js",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "bitecs": "^0.3.40",
    "phaser": "^3.90.0"
  }
}
